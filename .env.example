# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=spliteasy
# TLS to the database. Defaults to "require"; a local Postgres without SSL needs
# "disable". Use "require" (or stricter) for any remote/managed database.
DB_SSLMODE=disable

# Google OAuth2 — obtener en: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=client-id-mock
GOOGLE_CLIENT_SECRET=client-secret-mock
# Debe coincidir con un Authorized redirect URI configurado en el Client ID de Google Cloud Console
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

# JWT — usar una clave larga y aleatoria en producción
JWT_SECRET=change-me-to-a-secure-random-string

# URL del frontend a la que se redirige tras el login, con el JWT en el fragment (#token=...)
FRONTEND_REDIRECT_URL=http://localhost:8081/auth/callback

# Orígenes permitidos por CORS, separados por coma. En producción debe ser el
# dominio del frontend (ej: https://spliteasy-app.onrender.com), sin wildcard.
CORS_ALLOWED_ORIGINS=http://localhost:8081

# Anthropic (Claude) — usado para escanear/parsear fotos de tickets. Obtener en: https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Rate limit del endpoint de escaneo de tickets (por usuario). Protege el
# presupuesto de Anthropic. Defaults: 10/hora sostenido, ráfaga de 5.
SCAN_RATE_PER_HOUR=10
SCAN_RATE_BURST=5

# Si está seteada, los contadores del rate limiter se guardan en Redis (sobreviven
# a restarts/deploys y se comparten entre instancias). Si no está seteada, cae a un
# limiter en memoria (suficiente para dev local, no recomendado en producción).
REDIS_URL=
