# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=spliteasy

# Google OAuth2 — obtener en: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=client-id-mock
GOOGLE_CLIENT_SECRET=client-secret-mock
# Debe coincidir con un Authorized redirect URI configurado en el Client ID de Google Cloud Console
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

# JWT — usar una clave larga y aleatoria en producción
JWT_SECRET=change-me-to-a-secure-random-string

# URL del frontend a la que se redirige tras el login, con el JWT como query param (?token=...)
FRONTEND_REDIRECT_URL=http://localhost:8081/auth/callback
